{
  "name": "@rcompat/net",
  "version": "0.0.1",
  "description": "Standard library TCP/Unix sockets",
  "bugs": "https://github.com/rcompat/rcompat/issues",
  "license": "MIT",
  "files": [
    "/lib/**/*.js",
    "/lib/**/*.d.ts",
    "!/**/*.spec.*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rcompat/rcompat",
    "directory": "packages/net"
  },
  "scripts": {
    "build": "npm run clean && tsgo",
    "test": "npx proby",
    "clean": "rm -rf ./lib",
    "lint": "eslint .",
    "prepublishOnly": "npm run build"
  },
  "type": "module",
  "imports": {
    "#connect": {
      "bun": {
        "apekit": "./src/private/connect/bun.ts",
        "default": "./lib/private/connect/bun.js"
      },
      "deno": {
        "apekit": "./src/private/connect/deno.ts",
        "default": "./lib/private/connect/deno.js"
      },
      "default": {
        "apekit": "./src/private/connect/node.ts",
        "default": "./lib/private/connect/node.js"
      }
    },
    "#*": {
      "apekit": "./src/private/*.ts",
      "default": "./lib/private/*.js"
    }
  },
  "exports": {
    ".": {
      "apekit": "./src/public/index.ts",
      "default": "./lib/public/index.js"
    }
  }
}
